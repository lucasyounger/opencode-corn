{
  "name": "opencode-corn",
  "version": "0.2.3",
  "description": "An OpenCode plugin that manages scheduled agent jobs through a resident gateway service.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "opencode-corn-gateway": "dist/src/bin/gateway.js",
    "opencode-corn-runner": "dist/src/bin/runner.js",
    "opencode-corn-manage": "dist/src/bin/manage.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build",
    "test": "node --test --experimental-test-isolation=none dist/tests/**/*.test.js"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.4.7",
    "@opencode-ai/sdk": "^1.4.7",
    "cron-parser": "^5.2.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "typescript": "^5.8.2"
  }
}
